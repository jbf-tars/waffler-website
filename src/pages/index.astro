---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/sections/Hero.astro";
import SpeedStat from "../components/sections/SpeedStat.astro";
import HowItWorks from "../components/sections/HowItWorks.astro";
import Features from "../components/sections/Features.astro";
import Privacy from "../components/sections/Privacy.astro";
import FAQ from "../components/sections/FAQ.astro";
import FinalCTA from "../components/sections/FinalCTA.astro";
---

<BaseLayout
  title="Waffler — Free Open-Source Voice-to-Text for Mac & Windows"
  description="Press a hotkey, speak, release — polished text lands in your clipboard. Free, open source, bring your own OpenAI or Groq API key. No account required."
>
  <Hero />
  <SpeedStat />
  <HowItWorks />
  <Features />
  <Privacy />
  <FAQ />
  <FinalCTA />

  <script>
    import { initDownloadButtons } from "../scripts/os-detect";
    initDownloadButtons();
  </script>
</BaseLayout>
